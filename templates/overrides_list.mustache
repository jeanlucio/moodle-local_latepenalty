{{!
    @template local_latepenalty/overrides_list

    Table listing all per-user late penalty overrides for a given activity.

    Context variables required for this template:
    * hasrows - Boolean: true when at least one override exists.
    * rows    - Array of override rows: fullname, deadline, daily_penalty,
                max_penalty, editurl, deleteurl.

    Example context (json):
    {
        "hasrows": true,
        "rows": [
            {
                "fullname": "João Silva",
                "deadline": "12 May 2026",
                "daily_penalty": "5%",
                "max_penalty": "30%",
                "editurl": "/local/latepenalty/overrides.php?cmid=1&action=edit&overrideid=2",
                "deleteurl": "/local/latepenalty/overrides.php?cmid=1&action=delete&overrideid=2"
            }
        ]
    }
}}
<div class="local-latepenalty-overrides mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            {{#hasrows}}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">{{#str}} override_col_student, local_latepenalty {{/str}}</th>
                            <th scope="col">{{#str}} override_col_deadline, local_latepenalty {{/str}}</th>
                            <th scope="col">{{#str}} override_col_daily, local_latepenalty {{/str}}</th>
                            <th scope="col">{{#str}} override_col_max, local_latepenalty {{/str}}</th>
                            <th scope="col" aria-label="{{#str}} actions, moodle {{/str}}"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#rows}}
                        <tr>
                            <td>{{fullname}}</td>
                            <td>{{deadline}}</td>
                            <td>{{daily_penalty}}</td>
                            <td>{{max_penalty}}</td>
                            <td>
                                <a href="{{editurl}}">{{#str}} override_edit, local_latepenalty {{/str}}</a>
                                &middot;
                                <a href="{{deleteurl}}">{{#str}} override_delete, local_latepenalty {{/str}}</a>
                            </td>
                        </tr>
                        {{/rows}}
                    </tbody>
                </table>
            </div>
            {{/hasrows}}
        </div>
    </div>
</div>
