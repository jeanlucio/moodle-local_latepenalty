{{!
    @template local_latepenalty/overrides_tabs

    Template for the overrides mode selector tabs.

    Example context (json):
    {
        "usermodeurl": "#",
        "groupmodeurl": "#",
        "useractive": true,
        "groupactive": false
    }
}}
<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a href="{{usermodeurl}}" class="nav-link {{#useractive}}active{{/useractive}}">
            {{#str}} overrides_mode_user, local_latepenalty {{/str}}
        </a>
    </li>
    <li class="nav-item">
        <a href="{{groupmodeurl}}" class="nav-link {{#groupactive}}active{{/groupactive}}">
            {{#str}} overrides_mode_group, local_latepenalty {{/str}}
        </a>
    </li>
</ul>
